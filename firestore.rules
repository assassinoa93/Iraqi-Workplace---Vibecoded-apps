rules_version = '2';

// Iraqi Labor Scheduler — Firestore security rules.
// Phase 1 baseline: only the /users collection is accessed from the client.
// Phase 2 will open subcollections per the migration plan in
// C:\Users\RG\.claude\plans\if-i-want-to-polymorphic-brook.md.

service cloud.firestore {
  match /databases/{database}/documents {

    function role()         { return request.auth.token.role; }
    function isSuper()      { return request.auth != null && role() == 'super_admin'; }
    function isAdmin()      { return request.auth != null && (role() == 'admin' || isSuper()); }
    // v5.0 — manager is the first-tier validator. Sits between admin and
    // supervisor. Scoped via `allowedCompanies` claim like supervisor.
    function isManager()    { return request.auth != null && role() == 'manager'; }
    function isSupervisor() { return request.auth != null && role() == 'supervisor'; }
    function hasCompany(c)  { return isSuper() || isAdmin() || ((isManager() || isSupervisor()) && request.auth.token.companies is list && c in request.auth.token.companies); }

    // /users — super_admin reads/writes all; users read their own doc.
    match /users/{uid} {
      allow read:  if isSuper() || (request.auth != null && request.auth.uid == uid);
      allow write: if isSuper();
    }

    // /companies and subcollections — Phase 2 will populate this.
    match /companies/{companyId} {
      allow read:  if isAdmin() || hasCompany(companyId);
      allow write: if isSuper();

      // v5.1.3 — operating-window fields manager + supervisor are allowed
      // to mutate inside the config doc. Governance fields (Iraqi Labor
      // Law caps, pay rates, weekend policy, Ramadan, hazardous, driver)
      // stay admin-only. Defined as a constant so the rule below stays
      // readable and so adding / removing operating-window fields in the
      // future is a single-line change.
      function operatingWindowKeys() {
        return ['shopOpeningTime', 'shopClosingTime', 'operatingHoursByDayOfWeek'];
      }
      function configWriteAllowed() {
        return isAdmin()
          || (
            (isManager() || isSupervisor())
            && resource != null
            && request.resource.data.value.diff(resource.data.value).affectedKeys().hasOnly(operatingWindowKeys())
          );
      }

      match /{collection}/{docId} {
        allow read: if hasCompany(companyId);
        // Supervisors edit operational data; config is governance —
        // admin+ can write any field, manager + supervisor can update
        // operating-window fields only (see configWriteAllowed above).
        allow write: if hasCompany(companyId) &&
                       (collection != 'config' || configWriteAllowed());
      }

      match /schedules/{month} {
        allow read:  if hasCompany(companyId);
        allow write: if hasCompany(companyId);

        // v5.0 — saved snapshots. Created when an admin transitions a
        // schedule to `saved`. Immutable record-keeping artifact: any user
        // with company access can read; only admin/super can create; never
        // updated or deleted (preserves audit lineage).
        match /snapshots/{snapshotId} {
          allow read:   if hasCompany(companyId);
          allow create: if hasCompany(companyId) && isAdmin();
          allow update, delete: if false;
        }
      }
    }

    // /audit — admins read all, manager + supervisor read entries scoped to
    // their companies (so a manager can review the audit trail of schedules
    // they validate).
    match /audit/{entryId} {
      allow read:   if isAdmin() ||
                       ((isManager() || isSupervisor()) && hasCompany(resource.data.companyId));
      allow create: if request.auth != null;
      allow update, delete: if false;
    }
  }
}
